{
  "version": 2,
  "builds": [{ "src": "index.js", "use": "@vercel/node" }],
  "routes": [
    {
      "src": "/_vercel/insights/(.*)",
      "continue": true
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    { 
      "src": "/(.*)", 
      "dest": "/index.js" 
    }
  ]
}
